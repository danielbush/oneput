#!/bin/sh
#
# Tracked pre-commit-user hook. Installed into .git/hooks/pre-commit-user
# via scripts/hooks/install.sh (run once after clone).
#
# Checks formatting and package checks without mutating the worktree.
#
# GitButler: this is invoked by GitButler's managed .git/hooks/pre-commit,
# which delegates to pre-commit-user before its workspace-branch guard.
#

cd "$(git rev-parse --show-toplevel)" || exit 1

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "Running task format:check..."
task format:check &
FORMAT_PID=$!

echo "Running task check..."
task check &
CHECK_PID=$!

STATUS=0
if ! wait "$FORMAT_PID"; then
    echo "task format:check failed. Run task format and stage the result before committing."
    STATUS=1
fi

if ! wait "$CHECK_PID"; then
    echo "task check failed. Fix the issues before committing."
    STATUS=1
fi

exit "$STATUS"
