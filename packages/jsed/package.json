{
  "name": "@oneput/jsed",
  "version": "0.0.1",
  "description": "",
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./ui/oneput/app": {
      "import": "./src/ui/oneput/app/index.ts",
      "types": "./src/ui/oneput/app/index.ts"
    },
    "./styles/jsed-defaults.css": "./src/styles/jsed-defaults.css"
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./ui/oneput/app": {
        "import": "./dist/ui/oneput/app/index.js",
        "types": "./dist/ui/oneput/app/index.d.ts"
      },
      "./styles/jsed-defaults.css": "./dist/styles/jsed-defaults.css"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "private": false,
  "scripts": {
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest --run --reporter dot",
    "test:coverage": "vitest --run --coverage",
    "test:update": "vitest -u",
    "test:watch": "vitest --watch",
    "convert": "bun run src/cli/convert.ts",
    "dev": "vite",
    "build:check": "tsc",
    "build:types": "tsc -p tsconfig.d.json",
    "build:cli": "bun build ./src/cli/convert.ts --compile --outfile dist/bin/convert",
    "build:styles": "mkdir -p dist/styles && cp src/styles/jsed-defaults.css dist/styles/jsed-defaults.css",
    "build:watch": "bunx nodemon --ext js,jsx,ts,tsx,cjs,mjs,json --watch src --exec \"bun run build\"",
    "build": "bunx rimraf dist; bun run build:check && vite build && bun run build:types && bun run build:cli && bun run build:styles",
    "preview": "vite preview"
  },
  "bin": {
    "convert": "./dist/bin/convert"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/dom": "^8.20.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^18.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "@oneput/oneput": "workspace:",
    "commander": "^11.1.0",
    "lucide": "^0.562.0",
    "markdown-it": "^13.0.1",
    "neverthrow": "catalog:"
  },
  "nodemonConfig": {
    "ext": "css,ts,js,mjs,yaml,yml,json",
    "watch": [
      "src"
    ],
    "ignore": [
      "**/dist/**",
      "**/build/**",
      "**/node_modules/**",
      "**/test/**",
      "**/docs/**"
    ],
    "delay": 10
  }
}
