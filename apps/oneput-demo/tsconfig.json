{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "preserveSymlinks": false,
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "$app/types": ["./types/index.d.ts"],
      "@oneput/oneput": ["../../packages/oneput/src/lib/index.ts"],
      "@oneput/oneput/shared/*": ["../../packages/oneput/src/lib/oneput/shared/*"]
    }
  }
}
