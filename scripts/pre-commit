#!/bin/sh
#
# Pre-commit hook to run task check and task fix
# This hook runs before each commit to ensure code quality
#

echo "Running pre-commit checks..."

# Change to the project root directory (where Taskfile.yml is located)
cd "$(git rev-parse --show-toplevel)"

# Run task check first
echo "Running task check..."
if ! task check; then
    echo "❌ task check failed. Please fix the issues before committing."
    exit 1
fi

# Run task fix to automatically fix any formatting/linting issues
echo "Running task fix..."
if ! task fix; then
    echo "❌ task fix failed. Please fix the issues before committing."
    exit 1
fi

# Check if any files were modified by task fix
if ! git diff --quiet; then
    echo "📝 task fix modified some files. Adding them to the commit..."
    git add -A
fi

echo "✅ Pre-commit checks passed!"
exit 0
