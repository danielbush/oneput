{
  "$schema": "https://btca.dev/btca.schema.json",
  "dataDirectory": ".btca",
  "resources": [
    {
      "type": "git",
      "name": "svelte",
      "url": "https://github.com/sveltejs/svelte",
      "branch": "main"
    },
    {
      "type": "git",
      "name": "svelte-kit",
      "url": "https://github.com/sveltejs/kit",
      "branch": "main"
    }
  ],
  "model": "big-pickle",
  "provider": "opencode"
}