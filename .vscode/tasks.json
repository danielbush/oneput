{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"options": {
		"shell": {
			"executable": "/bin/zsh",
			"args": ["-l", "-c"]
		}
	},
	"tasks": [
		{
			"label": "check",
			"type": "shell",
			"command": "source ~/.zshrc && /usr/local/bin/task check",
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "fix",
			"type": "shell",
			"command": "source ~/.zshrc && /usr/local/bin/task fix",
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "format",
			"type": "shell",
			"command": "source ~/.zshrc && /usr/local/bin/task format",
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		}
	]
}
