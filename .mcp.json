{
  "mcpServers": {
    "btca-local": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "btca",
        "mcp"
      ]
    },
    "jcodemunch": {
      "command": "uvx",
      "args": [
        "jcodemunch-mcp"
      ],
      "env": {}
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}
