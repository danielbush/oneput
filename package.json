  "main": "index.js",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "rimraf build && tsc",
    "build:watch": "rimraf build && tsc --watch",
    "build:cjs": "rimraf dist && tsc --module commonjs --target es5 --outDir dist/cjs",
    "build:cjs:watch": "rimraf dist && tsc --watch --module commonjs --target es5 --outDir dist/cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "dev": "node ./scripts/live-server.js",
    "convert": "node ./dist/cjs/cli/convert.js"
  },
  "keywords": [],
