{
  "name": "@oneput/oneput",
  "description": "Who needs forms?  Use oneput.",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.8.2"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "types": "./src/lib/index.ts",
  "svelte": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./shared/*": "./src/lib/oneput/shared/*",
    "./demo/styles.css": "./src/routes/_demo-styles.css"
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "svelte": "./dist/index.js",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "svelte": "./dist/index.js"
      },
      "./shared/*": "./dist/oneput/shared/*"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "happy-dom": "^18.0.1",
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@sveltejs/adapter-auto": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser": "^3.2.3",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "catalog:",
    "globals": "^16.0.0",
    "idb": "^8.0.3",
    "katex": "^0.16.25",
    "playwright": "^1.53.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "catalog:",
    "publint": "^0.3.2",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.4",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-mkcert": "^1.17.9",
    "vitest": "^3.2.3",
    "vitest-browser-svelte": "catalog:"
  },
  "keywords": [
    "svelte"
  ],
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "debounce": "^2.2.0",
    "lucide": "^0.501.0",
    "neverthrow": "catalog:",
    "tinykeys": "^3.0.0"
  }
}
