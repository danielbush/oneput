    "@types/markdown-it": "^12.2.3",
    "jsdom": "^20.0.3",
    "live-server": "^1.2.2",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.5.4",
    "ts-node": "^10.7.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "markdown-it": "^13.0.1"
  }
