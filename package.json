{
  "name": "sbr-hyper-core",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "rimraf dist && mkdir -p dist/es && ( npm run build:es & npm run build:cjs & npm run build:style )",
    "build:watch": "nodemon --exec 'npm run build'",
    "build:es": "tsc --outDir dist/es --module ES2020",
    "build:cjs": "tsc --outDir dist/cjs --module commonjs",
    "build:style": "cp src/style.css dist/es/",
    "test": "jest",
    "test:update": "jest -u",
    "test:watch": "jest --watch",
    "dev": "node ./scripts/live-server.js",
    "convert:ng-ml": "nodemon --exec 'node ./dist/cjs/cli/convert.js src/examples/ng-ml/index.md >src/examples/ng-ml/index.html'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^29.3.1",
    "@types/jest": "^26.0.22",
    "@types/jsdom": "^20.0.1",
    "@types/markdown-it": "^12.2.3",
    "jsdom": "^20.0.3",
    "live-server": "^1.2.2",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.5.4",
    "ts-node": "^10.7.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "markdown-it": "^13.0.1"
  },
  "nodemonConfig": {
    "ext": "ts,js,mjs,yaml,yml,json",
    "watch": [
      "src"
    ],
    "ignore": [
      "**/dist/**",
      "**/build/**",
      "**/node_modules/**",
      "**/test/**",
      "**/docs/**"
    ],
    "delay": 10
  }
}