{
  "name": "jsed",
  "version": "0.0.1",
  "description": "",
  "main": "dist/index.js",
  "private": true,
  "type": "module",
  "types": "dist/src",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest --run --coverage",
    "test:update": "vitest -u",
    "test:watch": "vitest --watch",
    "convert": "bun run src/cli/convert.ts",
    "dev": "vite",
    "build:cli": "bun build ./src/cli/convert.ts --compile --outfile dist/bin/convert",
    "build:tsdefs": "tsc --emitDeclarationOnly --noEmit false --declaration --outDir dist",
    "build:watch": "bunx nodemon --ext js,jsx,ts,tsx,cjs,mjs,json --watch src --exec \"bun run build\"",
    "build": "bunx rimraf dist; bun run build:bun && bun run build:tsdefs && bun run build:cli",
    "build:bun": "bun build --target=node --outdir=dist --root=src src",
    "build:vite": "tsc && vite build",
    "preview": "vite preview"
  },
  "bin": {
    "convert": "./dist/bin/convert"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@testing-library/dom": "^8.20.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jsdom": "^20.0.1",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^16.18.8",
    "@vitest/coverage-v8": "^1.1.0",
    "jsdom": "^20.0.3",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "commander": "^11.1.0",
    "markdown-it": "^13.0.1"
  },
  "nodemonConfig": {
    "ext": "css,ts,js,mjs,yaml,yml,json",
    "watch": [
      "src"
    ],
    "ignore": [
      "**/dist/**",
      "**/build/**",
      "**/node_modules/**",
      "**/test/**",
      "**/docs/**"
    ],
    "delay": 10
  }
}