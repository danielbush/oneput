{
  "$schema": "https://btca.dev/btca.schema.json",
  "dataDirectory": ".btca",
  "resources": [
    {
      "type": "git",
      "name": "svelte-dev",
      "url": "https://github.com/sveltejs/svelte.dev",
      "branch": "main"
    },
    {
      "type": "git",
      "name": "vitest",
      "url": "https://github.com/vitest-dev/vitest",
      "branch": "main",
      "searchPath": "docs"
    }
  ],
  "model": "big-pickle",
  "provider": "opencode"
}