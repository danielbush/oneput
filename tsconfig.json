{
  "include": [
    "src/**/*.ts",
  ],
  "exclude": [
    "build/",
    "**/__tests__/"
  ],
  "compilerOptions": {
    "target": "es2017",
    "typeRoots": [
      "src/@types",
      "node_modules/@types",
      "../../node_modules/@types"
    ],
    "module": "commonjs",
    // "moduleResolution": "node",
    "outDir": "./build/",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true /* Skip type checking all .d.ts files. */
  }
}