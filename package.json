{
  "name": "sbr-hyper-core",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "check": "tsc --noEmit",
    "esbuild": "esbuild",
    "build:prepare": "npm run check && rimraf dist && mkdir dist && cp src/style.css dist",
    "build:cli": "esbuild src/convert.ts --target=node18 --bundle --outdir=dist/cli",
    "build": "npm run build:prepare && esbuild src/sketch.ts --bundle --outdir=dist --platform=browser",
    "test": "jest --coverage",
    "test:update": "jest -u",
    "test:watch": "jest --watch --coverage",
    "dev": "npm run build:prepare && esbuild src/sketch.ts --watch --bundle --servedir=src --outdir=src/.esbuild",
    "convert:ng-mlold": "npm run build:cli && node ./dist/cli/convert.js src/examples/ng-ml/index.md >src/examples/ng-ml/index.html'",
    "convert:ng-ml": "ts-node src/cli/convert.ts src/examples/ng-ml/index.md >src/examples/ng-ml/index.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^29.3.1",
    "@testing-library/dom": "^8.20.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^26.0.22",
    "@types/jsdom": "^20.0.1",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^16.18.8",
    "esbuild": "^0.17.5",
    "jsdom": "^20.0.3",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.5.4",
    "ts-node": "^10.7.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "@iktakahiro/markdown-it-katex": "^4.0.1",
    "hotkeys-js": "^3.10.1",
    "markdown-it": "^13.0.1"
  },
  "nodemonConfig": {
    "ext": "css,ts,js,mjs,yaml,yml,json",
    "watch": [
      "src"
    ],
    "ignore": [
      "**/dist/**",
      "**/build/**",
      "**/node_modules/**",
      "**/test/**",
      "**/docs/**"
    ],
    "delay": 10
  }
}