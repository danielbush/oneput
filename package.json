    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^26.0.22",
    "@types/jsdom": "^20.0.1",
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^16.18.8",
    "esbuild": "^0.17.5",
    "jsdom": "^20.0.3",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.5.4",
    "ts-node": "^10.7.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "dependencies": {
