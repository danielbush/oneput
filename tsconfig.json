{
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "build/",
    "**/__tests__/"
  ],
  "compilerOptions": {
    "target": "es2016",
    "module": "ES2020",
    "outDir": "./build/",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true /* Skip type checking all .d.ts files. */
  }
}